{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A bakery product available for purchase.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "category": {
          "type": "string",
          "description": "The category of the product (e.g., Cupcakes, Cakes)."
        },
        "image": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the product image."
        },
        "alt": {
          "type": "string",
          "description": "Alternative text for the product image."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "stockQuantity": {
          "type": "integer",
          "minimum": 0,
          "description": "The number of items in stock."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "ingredients": {
          "type": "string",
          "description": "The ingredients of the product."
        },
        "nutrition": {
          "type": "string",
          "description": "Nutritional information for the product."
        },
        "dietaryTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Dietary tags for the product (e.g., Gluten-Free, Nut-Free)."
        }
      },
      "required": ["name", "category", "image", "alt", "price", "stockQuantity", "description", "ingredients", "nutrition", "dietaryTags"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The role of the user."
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The phone number of the user."
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string", "description": "e.g., Home, Work" },
              "firstName": { "type": "string" },
              "lastName": { "type": "string" },
              "street": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zipCode": { "type": "string" },
              "isDefault": { "type": "boolean" }
            },
            "required": ["id", "label", "firstName", "lastName", "street", "city", "state", "zipCode"]
          },
          "description": "A list of saved shipping addresses."
        }
      },
      "required": ["role"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite product.",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The ID of the favorited product."
        },
        "addedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the product was favorited."
        }
      },
      "required": ["productId", "addedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's past order.",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["productId", "name", "price", "quantity"]
          },
          "description": "The items in the order."
        },
        "total": {
          "type": "number",
          "description": "The total price of the order."
        },
        "status": {
          "type": "string",
          "enum": ["processing", "shipped", "out_for_delivery", "delivered", "cancelled"],
          "description": "The status of the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the order was placed."
        },
        "customerEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the customer."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who placed the order."
        }
      },
      "required": ["items", "total", "status", "createdAt", "customerEmail", "userId"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review left by a customer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "A collection of bakery products."
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": {
        "$ref": "#/entities/Review"
      },
      "description": "A collection of reviews for a product."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "A collection of users."
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": {
        "$ref": "#/entities/Favorite"
      },
      "description": "A user's favorite products."
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "A user's past orders."
    }
  }
}
